# ============================================
# Supabase配置示例文件
# 使用方法：复制此文件为 .env，然后填入实际值
# ============================================

# Supabase项目URL
# 格式: https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase匿名密钥（Anon Key）
# 在Supabase Dashboard → Project Settings → API 中获取
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# 注意事项：
# 1. 不要将真实的 .env 文件提交到Git仓库
# 2. .env 文件已在 .gitignore 中配置
# 3. 部署到ESA Pages时，在控制台配置环境变量
# ============================================
